import { useState } from 'react';
import { ArrowUpDown, Calendar, Clock, MapPin, Plus, X, ArrowRight } from 'lucide-react';
import { useNavigate } from 'react-router-dom';

export default function BookingCard() {
  const [tripType, setTripType] = useState('One Way');
  const [pickup, setPickup] = useState('');
  const [drop, setDrop] = useState('');
  const [pickupCity, setPickupCity] = useState('');
  const [date, setDate] = useState('');
  const [time, setTime] = useState('');
  const [returnDate, setReturnDate] = useState('');
  const [returnTime, setReturnTime] = useState('');
  const [packageType, setPackageType] = useState('');
  const [stops, setStops] = useState([]);
  
  const navigate = useNavigate();

  const handleSwap = () => {
    const temp = pickup;
    setPickup(drop);
    setDrop(temp);
  };

  const addStop = () => setStops([...stops, '']);
  const updateStop = (index, value) => {
    const newStops = [...stops];
    newStops[index] = value;
    setStops(newStops);
  };
  const removeStop = (index) => {
    setStops(stops.filter((_, i) => i !== index));
  };

  const handleCheckFare = (e) => {
    e.preventDefault();
    if (tripType !== 'Local Rental' && (!pickup || !drop)) {
      alert('Please enter pickup and drop locations');
      return;
    }
    if (tripType === 'Local Rental' && (!pickupCity || !packageType)) {
      alert('Please enter pickup city and select a package');
      return;
    }
    
    const bookingData = {
      tripType,
      pickup: tripType === 'Local Rental' ? pickupCity : pickup,
      drop: tripType !== 'Local Rental' ? drop : '',
      stops: tripType === 'Round Trip' ? stops : [],
      date,
      time,
      returnDate: tripType === 'Round Trip' ? returnDate : '',
      returnTime: tripType === 'Round Trip' ? returnTime : '',
      packageType: tripType === 'Local Rental' ? packageType : '',
      vehicle: '' // Default to empty since we removed the selector
    };

    navigate('/fare-results', { state: bookingData });
  };

  return (
    <div className="w-full max-w-[420px] shrink-0 bg-white rounded-[24px] shadow-2xl overflow-hidden relative z-20 flex flex-col h-full mt-4 md:mt-0 border border-slate-100">
      
      {/* Header */}
      <div className="bg-[#1e3b8a] px-6 pt-8 pb-10 text-center">
        <h3 className="text-white text-[22px] font-bold leading-tight mb-1">Book Your Ride</h3>
        <p className="text-blue-100 text-[13px] font-medium">Get Instant Price & Book Your Taxi</p>
      </div>

      <div className="p-6 pb-5 flex-grow">
        {/* Stylish Tabs */}
        <div className="flex bg-slate-50 p-1 rounded-lg mb-5 overflow-x-auto hide-scrollbar border border-slate-200 shadow-inner">
          {['One Way', 'Round Trip', 'Local Rental', 'Airport Transfer'].map((type) => (
            <button
              key={type}
              type="button"
              onClick={() => setTripType(type)}
              className={`flex-1 min-w-[90px] text-[11px] font-bold py-2 px-1 rounded-md transition-all whitespace-nowrap ${
                tripType === type 
                  ? 'bg-white text-[#0f172a] shadow-sm border border-slate-100' 
                  : 'text-slate-500 hover:text-blue-600'
              }`}
            >
              {type}
            </button>
          ))}
        </div>

        <form onSubmit={handleCheckFare} className="space-y-4">
          
          {/* Locations */}
          {tripType !== 'Local Rental' ? (
            <div className="relative flex flex-col gap-3">
              <div>
                <label className="block text-[11px] font-bold text-[#0f172a] mb-1.5 ml-1">{tripType === 'Airport Transfer' ? 'Airport / Pickup' : 'Pickup Location'}</label>
                <div className="border border-slate-200 rounded-[8px] p-2 flex items-center gap-3 bg-white shadow-sm">
                  <MapPin className="text-[#0aa63f] flex-shrink-0" size={16} />
                  <input
                    type="text"
                    placeholder={tripType === 'Airport Transfer' ? 'Ghaziabad' : 'Enter pickup location'}
                    value={pickup || ''}
                    onChange={(e) => setPickup(e.target.value)}
                    className="w-full text-[13px] font-semibold text-[#0f172a] placeholder-slate-400 outline-none bg-transparent"
                  />
                </div>
              </div>
              
              <div className="relative">
                <label className="block text-[11px] font-bold text-[#0f172a] mb-1.5 ml-1">Drop Location</label>
                <div className="border border-slate-200 rounded-[8px] p-2 flex items-center gap-3 bg-white shadow-sm">
                  <MapPin className="text-red-500 flex-shrink-0" size={16} />
                  <input
                    type="text"
                    placeholder="Enter drop city or hotel"
                    value={drop || ''}
                    onChange={(e) => setDrop(e.target.value)}
                    className="w-full text-[13px] font-semibold text-[#0f172a] placeholder-slate-400 outline-none bg-transparent"
                  />
                </div>
                <button
                  type="button"
                  onClick={handleSwap}
                  className="absolute right-4 -top-6 bg-white border border-slate-200 p-1.5 rounded-full hover:bg-slate-50 transition shadow-sm z-10 text-[#1e3b8a]"
                >
                  <ArrowUpDown size={14} />
                </button>
              </div>
            </div>
          ) : (
            <div>
              <label className="block text-[11px] font-bold text-[#0f172a] mb-1.5 ml-1">Pickup City</label>
              <div className="border border-slate-200 rounded-[8px] p-2 flex items-center gap-3 bg-white shadow-sm">
                <MapPin className="text-[#0aa63f] flex-shrink-0" size={16} />
                <input
                  type="text"
                  placeholder="Pickup City"
                  value={pickupCity || ''}
                  onChange={(e) => setPickupCity(e.target.value)}
                  className="w-full text-[13px] font-semibold text-[#0f172a] placeholder-slate-400 outline-none bg-transparent"
                />
              </div>
            </div>
          )}

          {/* Round Trip Stops */}
          {tripType === 'Round Trip' && (
            <div className="space-y-2">
              {stops.map((stop, index) => (
                <div key={index} className="flex items-center gap-2">
                  <div className="flex-1 border border-slate-200 rounded-xl p-2.5 flex items-center gap-3 bg-white shadow-sm">
                    <MapPin size={16} className="text-yellow-500 flex-shrink-0" />
                    <input 
                      type="text" 
                      placeholder="Enter stop or sightseeing place" 
                      value={stop || ''}
                      onChange={(e) => updateStop(index, e.target.value)}
                      className="w-full text-sm font-semibold text-slate-800 placeholder-slate-400 outline-none bg-transparent"
                    />
                  </div>
                  <button type="button" onClick={() => removeStop(index)} className="p-2 text-red-500 hover:bg-red-50 rounded-lg border border-red-100 transition flex-shrink-0">
                    <X size={16} />
                  </button>
                </div>
              ))}
              <button 
                type="button" 
                onClick={addStop}
                className="text-xs font-bold text-blue-600 flex items-center gap-1 hover:text-blue-800 transition"
              >
                <Plus size={14} /> Add Stop / Sightseeing
              </button>
            </div>
          )}

          {/* Date and Time Fields */}
          <div>
            <label className="block text-[11px] font-bold text-[#0f172a] mb-1.5 ml-1">Pickup Date & Time</label>
            <div className="grid grid-cols-2 gap-3">
              <div className="border border-slate-200 rounded-[8px] p-2 flex items-center gap-2 bg-white shadow-sm hover:border-blue-300 transition-colors">
                <Calendar size={16} className="text-slate-400 flex-shrink-0" />
                <input 
                  type="date" 
                  value={date || ''}
                  onChange={(e) => setDate(e.target.value)}
                  className="w-full text-[12px] font-semibold text-[#0f172a] outline-none bg-transparent" 
                />
              </div>
              <div className="border border-slate-200 rounded-[8px] p-2 flex items-center gap-2 bg-white shadow-sm hover:border-blue-300 transition-colors">
                <Clock size={16} className="text-slate-400 flex-shrink-0" />
                <input 
                  type="time" 
                  value={time || ''}
                  onChange={(e) => setTime(e.target.value)}
                  className="w-full text-[12px] font-semibold text-[#0f172a] outline-none bg-transparent" 
                />
              </div>
            </div>
          </div>

          {/* Round Trip Return Date/Time */}
          {tripType === 'Round Trip' && (
            <div className="grid grid-cols-2 gap-3 mt-3">
              <div className="border border-slate-200 rounded-[8px] p-2 flex items-center gap-2 bg-white shadow-sm hover:border-blue-300 transition-colors">
                <Calendar size={16} className="text-slate-400 flex-shrink-0" />
                <input 
                  type="date" 
                  value={returnDate || ''}
                  onChange={(e) => setReturnDate(e.target.value)}
                  className="w-full text-[12px] font-semibold text-[#0f172a] outline-none bg-transparent" 
                />
              </div>
              <div className="border border-slate-200 rounded-[8px] p-2 flex items-center gap-2 bg-white shadow-sm hover:border-blue-300 transition-colors">
                <Clock size={16} className="text-slate-400 flex-shrink-0" />
                <input 
                  type="time" 
                  value={returnTime || ''}
                  onChange={(e) => setReturnTime(e.target.value)}
                  className="w-full text-[12px] font-semibold text-[#0f172a] outline-none bg-transparent" 
                />
              </div>
            </div>
          )}

          {/* Local Rentals Packages */}
          {tripType === 'Local Rental' && (
            <div className="border border-slate-200 rounded-[8px] p-2 flex items-center gap-2 bg-white shadow-sm hover:border-blue-300 transition-colors">
              <Clock size={16} className="text-slate-400 flex-shrink-0" />
              <select 
                value={packageType || ''}
                onChange={(e) => setPackageType(e.target.value)}
                className="w-full text-[12px] font-semibold text-[#0f172a] outline-none bg-transparent"
              >
                <option value="">Select Package</option>
                <option value="2 hrs 20 kms">2 hrs 20 kms</option>
                <option value="4 hrs 40 kms">4 hrs 40 kms</option>
                <option value="6 hrs 60 kms">6 hrs 60 kms</option>
                <option value="8 hrs 80 kms">8 hrs 80 kms</option>
                <option value="10 hrs 100 kms">10 hrs 100 kms</option>
                <option value="12 hrs 120 kms">12 hrs 120 kms</option>
              </select>
            </div>
          )}

          <button
            type="submit"
            className="w-full bg-[#16a34a] text-white font-bold py-3.5 rounded-[10px] hover:bg-green-700 transition-all shadow-md flex items-center justify-center gap-2 text-[15px] mt-4"
          >
            Check Fare <ArrowRight size={18} />
          </button>
          
          <p className="text-center text-[11px] font-semibold text-slate-600 flex items-center justify-center gap-1.5 mt-2">
            <span className="text-yellow-500 font-black">⚡</span> Instant WhatsApp Confirmation
          </p>
        </form>
      </div>
    </div>
  );
}
